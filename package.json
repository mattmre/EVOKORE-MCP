{
  "name": "evokore-mcp",
  "version": "3.1.0",
  "description": "Multi-server MCP aggregator with skill discovery, HITL approval, RBAC, and session continuity",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "mcp.config.json",
    "voices.json",
    "damage-control-rules.yaml",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattmre/EVOKORE-MCP.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "docs:check": "vitest run test-docs-canonical-links.js test-ops-docs-validation.js",
    "repo:audit": "node scripts/repo-state-audit.js",
    "memory:sync": "node scripts/sync-memory.js",
    "build": "npx tsc",
    "benchmark:tool-discovery": "node scripts/benchmark-tool-discovery.js",
    "voice": "node dist/VoiceSidecar.js",
    "voice:dev": "npx tsx src/VoiceSidecar.ts",
    "test:voice:live": "node test-voice-sidecar-live-validation.js",
    "release:preflight": "node scripts/release-preflight.js",
    "release:check": "vitest run test-npm-release-flow-validation.js test-release-doc-freshness-validation.js",
    "prepack": "npm run build",
    "sync": "node scripts/sync-configs.js --apply",
    "sync:dry": "node scripts/sync-configs.js --dry-run",
    "replay": "node scripts/session-replay-view.js --latest",
    "hooks:view": "node scripts/hook-log-view.js",
    "dashboard": "node scripts/dashboard.js",
    "actions:quota": "node scripts/gh-actions-quota.js",
    "bench": "node scripts/benchmark.js",
    "docs:api": "typedoc",
    "worktree:cleanup": "node scripts/worktree-cleanup.js --dry-run",
    "worktree:cleanup:apply": "node scripts/worktree-cleanup.js --apply"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "aggregator",
    "multi-server",
    "skills",
    "hitl",
    "rbac",
    "claude",
    "ai-tools"
  ],
  "author": "EVOKORE",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "fuse.js": "^7.1.0",
    "jose": "^6.2.1",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@hono/node-server": "^1.19.11",
    "express-rate-limit": "^8.3.1",
    "hono": "^4.12.7"
  },
  "optionalDependencies": {
    "ioredis": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
