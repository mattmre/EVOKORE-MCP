{
  "skillRegistries": [],
  "servers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "fs": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "./"]
    },
    "elevenlabs": {
      "disabled": true,
      "_comment": "disabled 2026-04-24 — ELEVENLABS_API_KEY env var not provisioned; server was erroring on every boot. See issue #282 item #6. Re-enable once the API key is in the user's environment (and optional dep `uvx` / elevenlabs-mcp is confirmed installed).",
      "command": "uvx",
      "args": ["elevenlabs-mcp"],
      "env": {
        "ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY}",
        "ELEVENLABS_MCP_OUTPUT_MODE": "both"
      }
    },
    "supabase": {
      "disabled": true,
      "_comment": "disabled 2026-04-24 — SUPABASE_ACCESS_TOKEN env var not provisioned; server was erroring on every boot. See issue #282 item #6. Re-enable once the token is in the user's environment.",
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase", "--read-only"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "stitch": {
      "disabled": true,
      "_comment": "disabled 2026-04-24 — STITCH_API_KEY env var not provisioned AND upstream package `@google/stitch-mcp` may not exist on npm (npx resolution fails). See issue #282 item #6. Re-enable only after confirming both the package identity and the key.",
      "command": "npx",
      "args": ["-y", "@google/stitch-mcp"],
      "env": {
        "STITCH_API_KEY": "${STITCH_API_KEY}"
      }
    },
    "ghidra_headless": {
      "disabled": true,
      "command": "${EVOKORE_RE_GHIDRA_HEADLESS_PYTHON}",
      "args": ["-m", "ghidra_headless_mcp", "--ghidra-install-dir", "${GHIDRA_INSTALL_DIR}"],
      "cwd": "${EVOKORE_RE_GHIDRA_HEADLESS_REPO}"
    },
    "reva": {
      "disabled": true,
      "command": "${EVOKORE_RE_REVA_PYTHON}",
      "args": ["-m", "reva_cli"],
      "cwd": "${EVOKORE_RE_REVA_REPO}"
    },
    "binary_analysis": {
      "disabled": true,
      "command": "${EVOKORE_RE_BINARY_MCP_PYTHON}",
      "args": ["-m", "src.server"],
      "cwd": "${EVOKORE_RE_BINARY_MCP_REPO}",
      "env": {
        "GHIDRA_HOME": "${GHIDRA_INSTALL_DIR}",
        "WINDBG_PATH": "${WINDBG_PATH}",
        "X64DBG_BRIDGE_URL": "${X64DBG_BRIDGE_URL}"
      }
    }
  }
}
